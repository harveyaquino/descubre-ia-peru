# ─── Supabase ────────────────────────────────────────────────
# Project Settings > API en tu dashboard de Supabase.
# La URL es pública; la service_role key es SECRETA (solo server-side).
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ─── Anthropic (Claude) ──────────────────────────────────────
# console.anthropic.com > API Keys. Empieza con sk-ant-...
# Genera el análisis personalizado de cada lead. SECRETA.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── WhatsApp (botón flotante) ───────────────────────────────
# Número con código de país, solo dígitos. Es PÚBLICO (aparece en el botón).
# Si no se define, usa el número por defecto del código.
NEXT_PUBLIC_WHATSAPP_NUMBER=51979572350

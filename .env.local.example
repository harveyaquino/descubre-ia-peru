# ─── Supabase ────────────────────────────────────────────────
# Project Settings > API en tu dashboard de Supabase.
# La URL es pública; la service_role key es SECRETA (solo server-side).
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ─── Anthropic (Claude) ──────────────────────────────────────
# console.anthropic.com > API Keys. Empieza con sk-ant-...
# Genera el análisis personalizado de cada lead. SECRETA.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
